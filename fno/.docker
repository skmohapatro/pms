# --- Stable headless Chrome + Chromedriver + Java 17 on Debian 12 (recommended) ---
# Using Debian because Ubuntu Jammy's chromium is a snap (not apt) and breaks in Docker.
FROM debian:12-slim

# ===== System & Java =====
ENV TZ=Asia/Kolkata \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    CHROME_BIN=/usr/bin/chromium \
    CHROMEDRIVER=/usr/bin/chromedriver \
    JAVA_TOOL_OPTIONS="-XX:+ExitOnOutOfMemoryError -XX:+UseContainerSupport"

# Install Java 17, Chromium (apt), matching Chromedriver (apt), fonts, and tools
RUN apt-get update && apt-get install -y --no-install-recommends \
      openjdk-17-jre-headless \
      chromium chromium-driver \
      ca-certificates tzdata \
      fonts-liberation fonts-noto-color-emoji \
      fonts-ipafont-gothic fonts-wqy-zenhei fonts-thai-tlwg fonts-kacst \
      fonts-freefont-ttf \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 10001 appuser
WORKDIR /app

# Copy Spring Boot fat jar
# (Adjust the pattern if your jar has a fixed name)
COPY target/*.jar /app/app.jar

# Expose HTTP port
EXPOSE 8080

# Permissions & user
RUN chown -R appuser:appuser /app
USER appuser

# Default command
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
